{
  "name": "waymark",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @waymark/db",
    "db:check": "turbo run db:check -F @waymark/db",
    "db:studio": "turbo run db:studio -F @waymark/db",
    "db:generate": "turbo run db:generate -F @waymark/db",
    "db:migrate": "turbo run db:migrate -F @waymark/db",
    "db:start": "turbo run db:start -F @waymark/db",
    "db:watch": "turbo run db:watch -F @waymark/db",
    "db:stop": "turbo run db:stop -F @waymark/db",
    "db:down": "turbo run db:down -F @waymark/db"
  },
  "dependencies": {
    "@waymark/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@waymark/config": "workspace:*",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
