# Local PostgreSQL connection from packages/db/docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5433/waymark

# Change this if port 5433 is already in use.
WAYMARK_POSTGRES_PORT=5433

# Use a random value with at least 32 characters outside local development.
BETTER_AUTH_SECRET=replace-with-a-local-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

NODE_ENV=development
