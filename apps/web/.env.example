# Local PostgreSQL connection from packages/db/docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5433/waymark

# Change this if port 5433 is already in use.
WAYMARK_POSTGRES_PORT=5433

# Use a random value with at least 32 characters outside local development.
BETTER_AUTH_SECRET=replace-with-a-local-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Google OAuth credentials from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NODE_ENV=development

# tldraw production license key (browser-visible; obtain from tldraw)
VITE_TLDRAW_LICENSE_KEY=

# Local asset storage. Replace with R2/S3-compatible settings in production.
WAYMARK_ASSET_DIR=.data/assets
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
